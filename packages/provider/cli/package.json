{
  "name": "@agentproto/provider-cli",
  "version": "0.1.0-alpha.0",
  "description": "agentproto/cli-runtime — AIP-29 CLI provider specialisation. Sugar over @agentproto/provider for command-line binaries: argv templating, subprocess invocation, exit-code mapping, output parsing. v0.1 ships subprocess invocation; OS-level sandbox enforcement (network egress, fs ACLs, exec deny) is host policy and integrates with platform primitives in v0.2.",
  "keywords": ["agentproto", "aip-29", "cli", "provider", "subprocess"],
  "homepage": "https://agentproto.sh/docs/aip-29",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentproto/provider": "workspace:*",
    "@agentproto/tool": "workspace:*"
  },
  "devDependencies": {
    "@agentproto/tooling": "workspace:*",
    "@types/node": "^25.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
